# ── OpenAI ────────────────────────────────────────────────────────────────────
# Required for answer generation. Get yours at https://platform.openai.com/api-keys
OPENAI_API_KEY=sk-...

# LLM used for generation (default: gpt-4o-mini)
OPENAI_MODEL=gpt-4o-mini

# OpenAI embedding model (only used when EMBEDDING_BACKEND=openai)
OPENAI_EMBEDDING_MODEL=text-embedding-3-small

# ── Embeddings ────────────────────────────────────────────────────────────────
# "sentence_transformers" (local, no API key needed) | "openai"
EMBEDDING_BACKEND=sentence_transformers

# Sentence-Transformers model name (used when EMBEDDING_BACKEND=sentence_transformers)
SENTENCE_TRANSFORMER_MODEL=all-MiniLM-L6-v2

# ── Vector store ──────────────────────────────────────────────────────────────
# "chroma" (default, persistent) | "faiss" (in-memory, persisted to disk)
VECTOR_STORE_BACKEND=chroma

CHROMA_PERSIST_DIR=data/vector_store/chroma
CHROMA_COLLECTION_NAME=docurag_collection
FAISS_INDEX_PATH=data/vector_store/faiss.index

# ── Chunking ──────────────────────────────────────────────────────────────────
CHUNK_SIZE=1000
CHUNK_OVERLAP=200

# ── Retrieval ─────────────────────────────────────────────────────────────────
RETRIEVAL_TOP_K=5
# Leave blank to return all retrieved results regardless of score
RETRIEVAL_SCORE_THRESHOLD=

# ── Generation ────────────────────────────────────────────────────────────────
MAX_CONTEXT_CHARS=6000
LLM_TEMPERATURE=0.2

# ── Paths ─────────────────────────────────────────────────────────────────────
UPLOAD_DIR=data/uploads

# ── API server ────────────────────────────────────────────────────────────────
API_HOST=0.0.0.0
API_PORT=8000
